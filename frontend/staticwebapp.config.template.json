{
  "routes": [
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/app*.js",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/app-config*.js",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  }
}
